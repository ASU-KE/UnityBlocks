{
  "name": "asu-ke-web-services/unityblocks",
  "description": "UnityBlocks is a suite of page building content blocks for the ASU Web Standards Unity (UDS) WordPress theme.",
  "type": "wordpress-plugin",
  "license": "GPL-2.0-only",
  "require": {
    "php": ">=5.6"
  },
  "config": {
    "platform": {
      "php": "5.6"
    }
  },
  "require-dev": {
    "squizlabs/php_codesniffer": "^3.6",
    "dealerdirect/phpcodesniffer-composer-installer": "^0.7.1",
    "phpcompatibility/phpcompatibility-wp": "^2.1.2",
    "wp-coding-standards/wpcs": "^2.3.0",
    "phpunit/phpunit": "^5",
    "wp-cli/wp-cli-bundle": "^2.4"
  },
  "scripts": {
    "lint": "@php ./vendor/bin/phpcs",
    "lint-fix": "@php ./vendor/bin/phpcbf",
    "test": "@php ./vendor/bin/phpunit"
  }
}
