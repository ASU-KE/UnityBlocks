{
  "name": "unityblocks",
  "title": "UnityBlocks",
  "description": "UnityBlocks is a suite of page building content blocks for the ASU Web Standards Unity (UDS) WordPress theme.",
  "version": "1.0.0",
  "tested_up_to": "5.8",
  "author": "ASU KE Web Services",
  "license": "GPL-2.0",
  "repository": "ASU-KE/unityblocks",
  "homepage": "https://github.com/ASU-KE/unityblocks",
  "bugs": {
    "url": "https://github.com/ASU-KE/unityblocks/issues"
  },
  "scripts": {
    "setup": "composer install && npm install && npm run build && wp-env install",
    "start": "wp-scripts start --config .dev/config/webpack.config.js --progress",
    "build": "wp-scripts build --config .dev/config/webpack.config.js",
    "clean": "wp-env stop && rm -rf build dist/*.* dist/js node_modules vendor wordpress",
    "version": "grunt version && grunt update-pot && git add -A .",
    "postversion": "git push && git push --tags",
    "test:e2e": "cypress run --config video=false --browser chrome",
    "test:e2e:record": "cypress run --browser chrome",
    "test:e2e:debug": "npx cypress open",
    "env": "wp-env",
    "format": "wp-scripts format",
    "lint:css": "wp-scripts lint-style",
    "lint:css-fix": "wp-scripts lint-style --fix",
    "lint:js": "wp-scripts lint-js",
    "lint:php": "wp-env lint-php",
    "test:php": "wp-env test-php",
    "test:js": "wp-scripts test-unit-js --config .dev/tests/jest/jest.config.js",
    "test:js:coverage": "wp-scripts test-unit-js --config .dev/tests/jest/jest.config.js --coverage",
    "test:performance": "wp-scripts test-e2e --config .dev/performance/jest.performance.config.js",
    "wp-env": "wp-env"
  },
  "wp-env": {
    "plugin-dir": "unityblocks",
    "plugin-name": "UnityBlocks",
    "welcome-build-command": "npm run start"
  },
  "dependencies": {
    "@asu-design-system/components-core": "^1.20.0",
    "dompurify": "^2.2.7",
    "react-router-dom": "^5.2.0",
    "styled-components": "^5.3.3"
  },
  "devDependencies": {
    "@asu-ke-web-services/stylelint-config": "^0.1.0",
    "@babel/plugin-proposal-class-properties": "7.10.4",
    "@es-joy/jsdoccomment": "0.10.8",
    "@godaddy-wordpress/coblocks-icons": "^1.8.1",
    "@jest/core": "^27.3.1",
    "@testing-library/jest-dom": "^4.2.4",
    "@testing-library/react": "^12.0.0",
    "@wordpress/base-styles": "2.0.1",
    "@wordpress/block-editor": "3.1.0",
    "@wordpress/block-library": "2.8.0",
    "@wordpress/blocks": "^6.10.0",
    "@wordpress/dom": "~2.16.2",
    "@wordpress/e2e-test-utils": "^5.4.6",
    "@wordpress/edit-post": "3.7.0",
    "@wordpress/env": "^4.1.3",
    "@wordpress/eslint-plugin": "9.0.5",
    "@wordpress/i18n": "3.6.0",
    "@wordpress/jest-console": "^4.1.0",
    "@wordpress/jest-preset-default": "^7.1.2",
    "@wordpress/jest-puppeteer-axe": "^3.1.0",
    "@wordpress/plugins": "2.6.0",
    "@wordpress/postcss-themes": "^2.2.0",
    "@wordpress/prettier-config": "^1.1.1",
    "@wordpress/scripts": "16.1.0",
    "autoprefixer": "^9.7.5",
    "chalk": "^4.1.2",
    "copy-webpack-plugin": "^6.4.1",
    "css-loader": "^3.2.1",
    "cypress": "^6.9.1",
    "cypress-file-upload": "^5.0.8",
    "cypress-log-to-output": "1.1.2",
    "email-validator": "^2.0.4",
    "enzyme": "^3.11.0",
    "enzyme-adapter-react-16": "^1.15.6",
    "eslint-config-prettier": "^8.3.0",
    "eslint-plugin-chai-friendly": "^0.5.0",
    "eslint-plugin-cypress": "^2.10.3",
    "eslint-plugin-jsdoc": "36.1.0",
    "eslint-plugin-prettier": "^4.0.0",
    "expect-puppeteer": "^4.4.0",
    "flickity": "^2.2.2",
    "grunt": "^1.1.0",
    "grunt-contrib-clean": "^1.0.0",
    "grunt-contrib-compress": "^1.4.1",
    "grunt-contrib-copy": "^1.0.0",
    "grunt-shell": "^2.1.0",
    "grunt-text-replace": "^0.4.0",
    "grunt-wp-readme-to-markdown": "^2.1.0",
    "gzip-size": "^4.1.0",
    "html-react-parser": "^0.9.1",
    "husky": "^3.1.0",
    "jest": "^27.3.1",
    "jest-circus": "^26.6.3",
    "jest-environment-puppeteer": "^5.0.4",
    "jest-junit": "12.0.0",
    "jest-runner": "^27.3.1",
    "jquery": "^3.4.1",
    "jsdom": "^15.2.1",
    "lint-staged": "^9.5.0",
    "matchdep": "^2.0.0",
    "memize": "^1.0.5",
    "mini-css-extract-plugin": "^0.8.0",
    "node-sass": "^4.14.1",
    "node-sass-glob-importer": "^5.3.2",
    "postcss": "8.2.10",
    "postcss-color-function": "^4.1.0",
    "postcss-loader": "^3.0.0",
    "prettier": "npm:wp-prettier@^2.2.1-beta-1",
    "puppeteer": "^11.0.0",
    "react-flickity-component": "^3.4.0",
    "react-google-maps": "^9.4.5",
    "react-masonry-component": "^6.2.1",
    "react-share": "^4.4.0",
    "react-slick": "^0.25.2",
    "react-test-renderer": "^16.13.1",
    "reactstrap": "^8.10.1",
    "recompose": "^0.30.0",
    "sass-loader": "^8.0.0",
    "style-loader": "^0.19.1",
    "stylelint": "^13.13.1",
    "stylelint-config-prettier": "^8.0.2",
    "stylelint-prettier": "^1.2.0",
    "webpack-fix-style-only-entries": "^0.4.0"
  },
  "resolutions": {
    "css-what": "^5.0.1",
    "trim-newlines": "^3.0.1",
    "glob-parent": "^5.1.2",
    "ws": "^7.4.6",
    "trim": "^0.0.3",
    "node-fetch": "^2.6.1",
    "normalize-url": "^6.0.1",
    "yargs-parser": "^20.2.9"
  },
  "husky": {
    "hooks": {}
  },
  "lint-staged": {
    "*.scss": [
      "stylelint src/**/*.scss --fix"
    ],
    "*.js": [
      "wp-scripts test-unit-js --config .dev/tests/jest/jest.config.js --silent --findRelatedTests",
      "npm run lint:js"
    ],
    "*.php": [
      "composer run lint"
    ]
  }
}
