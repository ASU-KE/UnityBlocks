{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 2,
  "name": "unityblocks/news-list",
  "version": "1.0.0",
  "title": "Unity News List (DEPRECATED)",
  "category": "uds",
  "keywords": [
    "unityblocks",
    "news",
    "grid"
  ],
  "icon": "list-view",
  "description": "Provide a list layout of ASU and KE News stories.  This view is no longer recommended.",
  "supports": {
    "html": false,
    "align": [
      "wide",
      "full"
    ]
  },
  "textdomain": "unityblocks",
  "viewScript": [
    "file:./frontend.js",
    "unityblocks-news-list-view-script"
  ],
  "editorScript": "file:./index.js",
  "attributes": {
    "enableHeader": {
      "type": "boolean",
      "default": true
    },
    "headerText": {
      "type": "string",
      "default": "News List"
    },
    "headerColor": {
      "type": "string",
      "enum": [
        "dark",
        "white"
      ],
      "default": "dark"
    },
    "ctaText": {
      "type": "string",
      "default": "Click to see more news"
    },
    "ctaUrl": {
      "type": "string",
      "default": "https://news.asu.edu/"
    },
    "ctaColor": {
      "type": "string",
      "enum": [
        "gold",
        "maroon",
        "gray",
        "dark"
      ],
      "default": "maroon"
    },
    "cardButtonText": {
      "type": "string",
      "default": "Read news"
    },
    "cardButtonColor": {
      "type": "string",
      "enum": [
        "gold",
        "maroon",
        "gray",
        "dark"
      ],
      "default": "gold"
    },
    "cardButtonSize": {
      "type": "string",
      "enum": [
        "default",
        "small",
        "medium",
        "large"
      ],
      "default": "default"
    },
    "enableAsuDataSource": {
      "type": "boolean",
      "default": true
    },
    "asuDataSourceUrl": {
      "type": "string",
      "default": "https://cors.api.rtd.asu.edu/asunow.asu.edu:443/feeds-json/"
    },
    "asuDataSourceFeed": {
      "type": "string",
      "default": ""
    },
    "asuDataSourceFilters": {
      "type": "string",
      "default": ""
    },
    "enableKeDataSource": {
      "type": "boolean",
      "default": false
    },
    "keDataSourceUrl": {
      "type": "string",
      "default": "https://ke.news.prod.rtd.asu.edu/wp-json/wp/v2/posts?"
    },
    "keDataSourceUnits": {
      "type": "string",
      "default": ""
    },
    "keDataSourceInterests": {
      "type": "string",
      "default": ""
    },
    "keDataSourceLocations": {
      "type": "string",
      "default": ""
    },
    "maxItems": {
      "type": "number",
      "default": 4
    }
  }
}