{
  "name": "unityblocks/events-list",
  "category": "widgets",
  "attributes": {
    "enableHeader": {
      "type": "boolean",
      "default": true
    },
    "headerText": {
      "type": "string",
      "default": "Events List"
    },
    "headerColor": {
      "enum": [
        "white",
        "dark"
      ],
      "default": "dark"
    },
    "ctaText": {
      "type": "string",
      "default": "Click to see more events"
    },
    "ctaUrl": {
      "type": "string",
      "default": "https://asuevents.asu.edu/"
    },
    "ctaColor": {
      "enum": [
        "gold",
        "maroon",
        "gray",
        "dark"
      ],
      "default": "maroon"
    },
    "dataSourceType": {
      "enum": [
        "asuDrupal",
        "keGraphql"
      ],
      "default": "keGraphql"
    },
    "dataSourceAsuUrl": {
      "type": "string",
      "default": "https://cors.api.rtd.asu.edu/asuevents.asu.edu/feed-json/"
    },
    "dataSourceKeUrl": {
      "type": "string",
      "default": "https://infonet.api.rtd.asu.edu/graphql/"
    },
    "keEventBasePath": {
      "type": "string",
      "default": "events/view"
    },
    "dataSourceFeed": {
      "type": "string",
      "default": "online"
    },
    "asuFilterUnits": {
      "type": "string",
      "default": ""
    },
    "keFilterUnits": {
      "type": "array",
      "default": []
    },
    "keSortEvents": {
      "enum": [
        "ASC",
        "DESC"
      ],
      "default": "ASC"
    },
    "keShowPastEvents": {
      "type": "boolean",
      "default": false
    },
    "maxItems": {
      "type": "number",
      "default": 4
    }
  }
}
