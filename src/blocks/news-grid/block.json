{
  "name": "unityblocks/news-grid",
  "category": "widgets",
  "attributes": {
    "enableHeader": {
      "type": "boolean",
      "default": true
    },
    "headerText": {
      "type": "string",
      "default": "News Grid"
    },
    "headerColor": {
      "enum": [
        "dark",
        "white"
      ],
      "default": "dark"
    },
    "ctaText": {
      "type": "string",
      "default": "Click to see more news"
    },
    "ctaUrl": {
      "type": "string",
      "default": "https://news.asu.edu/"
    },
    "ctaColor": {
      "enum": [
        "gold",
        "maroon",
        "gray",
        "dark"
      ],
      "default": "maroon"
    },
    "cardButtonText": {
      "type": "string",
      "default": "Read news"
    },
    "cardButtonColor": {
      "enum": [
        "gold",
        "maroon",
        "gray",
        "dark"
      ],
      "default": "gold"
    },
    "cardButtonSize": {
      "enum": [
        "default",
        "small",
        "medium",
        "large"
      ],
      "default": "default"
    },
    "dataSourceUrl": {
      "type": "string",
      "default": "https://cors.api.rtd.asu.edu/asunow.asu.edu:443/feeds-json/"
    },
    "dataSourceFeed": {
      "type": "string",
      "default": ""
    },
    "dataSourceFilters": {
      "type": "string",
      "default": ""
    },
    "maxItems": {
      "type": "number",
      "default": 6
    }
  }
}
