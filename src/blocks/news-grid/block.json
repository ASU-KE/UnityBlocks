{
  "name": "unityblocks/news-grid",
  "category": "widgets",
  "attributes": {
    "enableHeader": {
      "type": "boolean",
      "default": true
    },
    "headerText": {
      "type": "string",
      "default": "News Grid"
    },
    "headerColor": {
      "enum": [
        "dark",
        "white"
      ],
      "default": "dark"
    },
    "ctaText": {
      "type": "string",
      "default": "Click to see more news"
    },
    "ctaUrl": {
      "type": "string",
      "default": "https://news.asu.edu/"
    },
    "ctaColor": {
      "enum": [
        "gold",
        "maroon",
        "gray",
        "dark"
      ],
      "default": "maroon"
    },
    "cardButtonText": {
      "type": "string",
      "default": "Read news"
    },
    "cardButtonColor": {
      "enum": [
        "gold",
        "maroon",
        "gray",
        "dark"
      ],
      "default": "gold"
    },
    "cardButtonSize": {
      "enum": [
        "default",
        "small",
        "medium",
        "large"
      ],
      "default": "default"
    },
    "enableStoryDate": {
      "type": "boolean",
      "default": true
    },
    "enableStoryAuthor": {
      "type": "boolean",
      "default": true
    },
    "enableCardTags": {
      "type": "boolean",
      "default": false
    },
    "enableAsuDataSource": {
      "type": "boolean",
      "default": true
    },
    "asuDataSourceUrl": {
      "type": "string",
      "default": "https://cors.api.rtd.asu.edu/asunow.asu.edu:443/feeds-json/"
    },
    "asuDataSourceFeed": {
      "type": "string",
      "default": ""
    },
    "asuDataSourceFilters": {
      "type": "string",
      "default": ""
    },
    "enableKeDataSource": {
      "type": "boolean",
      "default": false
    },
    "keDataSourceUrl": {
      "type": "string",
      "default": "https://ke.news.prod.rtd.asu.edu/wp-json/wp/v2/posts?"
    },
    "keDataSourceUnits": {
      "type": "string",
      "default": ""
    },
    "keDataSourceInterests": {
      "type": "string",
      "default": ""
    },
    "keDataSourceLocations": {
      "type": "string",
      "default": ""
    },
    "maxItems": {
      "type": "number",
      "default": 6
    }
  }
}
