{
  "name": "unityblocks/events-grid",
  "category": "widgets",
  "attributes": {
    "enableHeader": {
      "type": "boolean",
      "default": true
    },
    "headerText": {
      "type": "string",
      "default": "Events Grid"
    },
    "headerColor": {
      "enum": [
        "white",
        "dark"
      ],
      "default": "dark"
    },
    "ctaText": {
      "type": "string",
      "default": "Click to see more events"
    },
    "ctaUrl": {
      "type": "string",
      "default": "https://asuevents.asu.edu/"
    },
    "ctaColor": {
      "enum": [
        "gold",
        "maroon",
        "gray",
        "dark"
      ],
      "default": "maroon"
    },
    "dataSourceType": {
      "enum": [
        "asuDrupal",
        "keGraphql",
        "wpRest"
      ],
      "default": "keGraphql"
    },
    "dataSourceUrl": {
      "type": "string",
      "default": "https://infonet.api.rtd.asu.edu/graphql/"
    },
    "dataSourceFeed": {
      "type": "string",
      "default": "online"
    },
    "dataSourceFilterCategories": {
      "type": "string",
      "default": "college-of-global-futures"
    },
    "dataSourcePage": {
      "type": "number",
      "default": 1
    },
    "dataSourcePerPage": {
      "type": "number",
      "default": 9
    },
    "dataSourceOrder": {
      "type": "string",
      "default": "DESC"
    },
    "dataSourceOrderBy": {
      "type": "string",
      "default": "startAt"
    },
    "maxItems": {
      "type": "number",
      "default": 6
    }
  }
}
