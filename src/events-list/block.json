{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 2,
  "name": "unityblocks/events-list",
  "version": "1.0.0",
  "title": "Unity Events List (DEPRECATED)",
  "category": "unityblocks",
  "keywords": ["unityblocks", "events", "list"],
  "icon": "list-view",
  "description": "Provide a list layout for ASU and KE Events. This view is no longer recommended.",
  "supports": {
    "html": false,
    "align": ["wide", "full"]
  },
  "textdomain": "unityblocks",
  "viewScript": ["file:./frontend.js", "unityblocks-events-list-view-script"],
  "editorScript": "file:./index.js",
  "attributes": {
    "enableHeader": {
      "type": "boolean",
      "default": true
    },
    "headerText": {
      "type": "string",
      "default": "Events List"
    },
    "headerColor": {
      "type": "string",
      "enum": ["white", "dark"],
      "default": "dark"
    },
    "ctaText": {
      "type": "string",
      "default": "Click to see more events"
    },
    "ctaUrl": {
      "type": "string",
      "default": "https://asuevents.asu.edu/"
    },
    "ctaColor": {
      "type": "string",
      "enum": ["gold", "maroon", "gray", "dark"],
      "default": "maroon"
    },
    "dataSourceType": {
      "type": "string",
      "enum": ["asuDrupal", "keGraphql"],
      "default": "keGraphql"
    },
    "dataSourceAsuUrl": {
      "type": "string",
      "default": "https://cors.api.rtd.asu.edu/asuevents.asu.edu/feed-json/"
    },
    "dataSourceKeUrl": {
      "type": "string",
      "default": "https://infonet.api.rtd.asu.edu/graphql/"
    },
    "keEventBasePath": {
      "type": "string",
      "default": "events/view"
    },
    "dataSourceFeed": {
      "type": "string",
      "default": "online"
    },
    "asuFilterUnits": {
      "type": "string",
      "default": ""
    },
    "keFilterUnits": {
      "type": "array",
      "default": []
    },
    "keSortEvents": {
      "type": "string",
      "enum": ["ASC", "DESC"],
      "default": "ASC"
    },
    "keShowPastEvents": {
      "type": "boolean",
      "default": false
    },
    "keShowFutureEvents": {
      "type": "boolean",
      "default": true
    },
    "noResultsText": {
      "type": "string",
      "default": "No events found"
    },
    "maxItems": {
      "type": "number",
      "default": 4
    }
  }
}
